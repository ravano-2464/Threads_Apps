{
   "name": "be-threads",
   "version": "0.0.1",
   "description": "Awesome project developed with TypeORM.",
   "type": "commonjs",
   "devDependencies": {
      "@types/bcrypt": "^5.0.1",
      "@types/express": "^4.17.20",
      "@types/jsonwebtoken": "^9.0.4",
      "@types/multer": "^1.4.9",
      "@types/node": "^16.11.10",
      "@types/swagger-ui-express": "^4.1.5",
      "concurrently": "^8.2.2",
      "multer": "^1.4.5-lts.1",
      "nodemon": "^3.0.1",
      "ts-node": "10.7.0",
      "typescript": "4.5.2"
   },
   "dependencies": {
      "amqplib": "^0.10.3",
      "bcrypt": "^5.1.1",
      "cloudinary": "^1.41.0",
      "cors": "^2.8.5",
      "dotenv": "^16.3.1",
      "express": "^4.18.2",
      "joi": "^17.11.0",
      "jsonwebtoken": "^9.0.2",
      "pg": "^8.4.0",
      "reflect-metadata": "^0.1.13",
      "swagger-ui-express": "^5.0.0",
      "tsoa": "^5.1.1",
      "typeorm": "0.3.17"
   },
   "scripts": {
      "start": "nodemon --exec ts-node src/index.ts",
      "worker": "nodemon --exec ts-node src/worker/index.ts",
      "predev": "npm run swagger",
      "prebuild": "npm run swagger",
      "build": "tsc",
      "dev": "concurrently \"nodemon\" \"nodemon -x tsoa spec\"",
      "swagger": "tsoa spec",
      "typeorm": "typeorm-ts-node-commonjs",
      "migration:generate": "npx typeorm-ts-node-commonjs migration:generate src/migration/MyMigration -d src/data-source.ts",
      "migration:run": "npx typeorm-ts-node-commonjs migration:run  -d src/data-source.ts"
   }
}
